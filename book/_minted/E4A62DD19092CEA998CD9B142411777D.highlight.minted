    \PYG{n}{n\PYGZus{}bootstrap}\PYG{o}{=}\PYG{l+m+mi}{1000}
\PYG{p}{)}

\PYG{c+c1}{\PYGZsh{} Interpretation: effect on the marginal 50th percentile}
