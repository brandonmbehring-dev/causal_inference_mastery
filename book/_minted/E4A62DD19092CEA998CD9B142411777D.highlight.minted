\PYG{k+kn}{from}\PYG{+w}{ }\PYG{n+nn}{causal\PYGZus{}inference}\PYG{n+nn}{.}\PYG{n+nn}{qte}\PYG{+w}{ }\PYG{k+kn}{import} \PYG{n}{rif\PYGZus{}qte}\PYG{p}{,} \PYG{n}{rif\PYGZus{}qte\PYGZus{}band}

\PYG{c+c1}{\PYGZsh{} RIF\PYGZhy{}OLS: unconditional QTE with covariate adjustment}
\PYG{n}{result} \PYG{o}{=} \PYG{n}{rif\PYGZus{}qte}\PYG{p}{(}
    \PYG{n}{outcome}\PYG{o}{=}\PYG{n}{y}\PYG{p}{,}
