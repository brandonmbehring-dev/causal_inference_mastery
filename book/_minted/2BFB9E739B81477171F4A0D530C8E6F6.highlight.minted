            \PYG{k}{break}

        \PYG{c+c1}{\PYGZsh{} Fit fluctuation: Y \PYGZti{} epsilon * H + offset(Q\PYGZus{}star)}
        \PYG{n}{epsilon} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{sum}\PYG{p}{(}\PYG{n}{H} \PYG{o}{*} \PYG{p}{(}\PYG{n}{outcomes} \PYG{o}{\PYGZhy{}} \PYG{n}{Q\PYGZus{}star}\PYG{p}{)}\PYG{p}{)} \PYG{o}{/} \PYG{n}{np}\PYG{o}{.}\PYG{n}{sum}\PYG{p}{(}\PYG{n}{H} \PYG{o}{*}\PYG{o}{*} \PYG{l+m+mi}{2}\PYG{p}{)}
        \PYG{n}{Q\PYGZus{}star} \PYG{o}{=} \PYG{n}{Q\PYGZus{}star} \PYG{o}{+} \PYG{n}{epsilon} \PYG{o}{*} \PYG{n}{H}
        \PYG{n}{epsilon\PYGZus{}total} \PYG{o}{+}\PYG{o}{=} \PYG{n}{epsilon}

