\PYG{p}{)} \PYG{o}{\PYGZhy{}}\PYG{o}{\PYGZgt{}} \PYG{n}{TMLEResult}\PYG{p}{:}
\PYG{+w}{    }\PYG{l+s+sd}{\PYGZdq{}\PYGZdq{}\PYGZdq{}}
\PYG{l+s+sd}{    Targeted Maximum Likelihood Estimation for ATE.}
\PYG{l+s+sd}{    \PYGZdq{}\PYGZdq{}\PYGZdq{}}
    \PYG{c+c1}{\PYGZsh{} Step 1: Initial estimation}
    \PYG{n}{propensity} \PYG{o}{=} \PYG{n}{estimate\PYGZus{}propensity}\PYG{p}{(}\PYG{n}{treatment}\PYG{p}{,} \PYG{n}{covariates}\PYG{p}{)}\PYG{p}{[}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{propensity}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{]}
    \PYG{n}{outcome\PYGZus{}result} \PYG{o}{=} \PYG{n}{fit\PYGZus{}outcome\PYGZus{}models}\PYG{p}{(}\PYG{n}{outcomes}\PYG{p}{,} \PYG{n}{treatment}\PYG{p}{,} \PYG{n}{covariates}\PYG{p}{)}
    \PYG{n}{Q0}\PYG{p}{,} \PYG{n}{Q1} \PYG{o}{=} \PYG{n}{outcome\PYGZus{}result}\PYG{p}{[}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{mu0\PYGZus{}predictions}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{]}\PYG{p}{,} \PYG{n}{outcome\PYGZus{}result}\PYG{p}{[}\PYG{l+s+s2}{\PYGZdq{}}\PYG{l+s+s2}{mu1\PYGZus{}predictions}\PYG{l+s+s2}{\PYGZdq{}}\PYG{p}{]}
    \PYG{n}{Q\PYGZus{}obs} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{where}\PYG{p}{(}\PYG{n}{treatment} \PYG{o}{==} \PYG{l+m+mi}{1}\PYG{p}{,} \PYG{n}{Q1}\PYG{p}{,} \PYG{n}{Q0}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Step 2: Clever covariate}
    \PYG{n}{H} \PYG{o}{=} \PYG{n}{treatment} \PYG{o}{/} \PYG{n}{propensity} \PYG{o}{\PYGZhy{}} \PYG{p}{(}\PYG{l+m+mi}{1} \PYG{o}{\PYGZhy{}} \PYG{n}{treatment}\PYG{p}{)} \PYG{o}{/} \PYG{p}{(}\PYG{l+m+mi}{1} \PYG{o}{\PYGZhy{}} \PYG{n}{propensity}\PYG{p}{)}

    \PYG{c+c1}{\PYGZsh{} Step 3: Targeting loop}
    \PYG{n}{Q\PYGZus{}star} \PYG{o}{=} \PYG{n}{Q\PYGZus{}obs}\PYG{o}{.}\PYG{n}{copy}\PYG{p}{(}\PYG{p}{)}
    \PYG{n}{epsilon\PYGZus{}total} \PYG{o}{=} \PYG{l+m+mf}{0.0}

    \PYG{k}{for} \PYG{n}{\PYGZus{}} \PYG{o+ow}{in} \PYG{n+nb}{range}\PYG{p}{(}\PYG{n}{max\PYGZus{}iter}\PYG{p}{)}\PYG{p}{:}
        \PYG{c+c1}{\PYGZsh{} Check convergence: score equation satisfied?}
        \PYG{n}{score} \PYG{o}{=} \PYG{n}{np}\PYG{o}{.}\PYG{n}{mean}\PYG{p}{(}\PYG{n}{H} \PYG{o}{*} \PYG{p}{(}\PYG{n}{outcomes} \PYG{o}{\PYGZhy{}} \PYG{n}{Q\PYGZus{}star}\PYG{p}{)}\PYG{p}{)}
