    \PYG{n}{H1}\PYG{p}{,} \PYG{n}{H0} \PYG{o}{=} \PYG{l+m+mi}{1} \PYG{o}{/} \PYG{n}{propensity}\PYG{p}{,} \PYG{o}{\PYGZhy{}}\PYG{l+m+mi}{1} \PYG{o}{/} \PYG{p}{(}\PYG{l+m+mi}{1} \PYG{o}{\PYGZhy{}} \PYG{n}{propensity}\PYG{p}{)}
